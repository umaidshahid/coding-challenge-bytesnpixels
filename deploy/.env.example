# Deployment environment for docker compose. Copy to .env in this folder:
#   cp deploy/.env.example deploy/.env
# Docker Compose reads deploy/.env automatically for ${VAR} interpolation.

# Required: signing secret for auth tokens. Use a long random value in production.
JWT_SECRET=change-me-in-production

# Host port the proxy listens on (open http://localhost:<PROXY_PORT>).
PROXY_PORT=8080

# Set to a domain (e.g. pulse.example.com) to enable automatic HTTPS.
# SITE_ADDRESS=pulse.example.com

# Summaries: leave FAKE_LLM=true to run offline with a canned summary.
FAKE_LLM=true
OPENAI_API_KEY=

# Which published image tag to deploy (docker-compose.yml / GHCR only).
IMAGE_TAG=latest
